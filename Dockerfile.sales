# Cron job for daily SALES update (PostgreSQL)
FROM mcr.microsoft.com/playwright:v1.57.0-noble

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Copy source and build
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

# Copy the scrape script
COPY scripts/daily-sales.sh ./scripts/
RUN chmod +x ./scripts/daily-sales.sh

ENV NODE_ENV=production
# DATABASE_URL is passed from Railway environment

# Run the sales script
CMD ["./scripts/daily-sales.sh"]
